<?xml version="1.0" encoding="utf-8"?>
<!--
  Public Dialplan - Voice Platform Call Routing
  All inbound calls are processed through Lua scripts for:
  - RCF (Remote Call Forwarding)
  - API Calling (webhook-driven)
  - SIP Trunk (customer PBX interconnect)

  Design Philosophy:
  - Fast path: Set variables, call Lua, let Lua handle routing
  - Security: Reject obviously invalid/malicious requests early
  - Logging: Capture key variables for debugging without overhead
  - Failsafe: Always have a final catch-all that rejects properly

  LOCAL TESTING ADDITIONS (for Zoiper):
  - Extensions 1001-1003 can call each other
  - Dial 555XXXX for test RCF DIDs (routes through Lua)
  - Default context for registered users

  DYNAMIC ROUTING via Lua Scripts:
  - inbound_router.lua: RCF, API DID, and Trunk DID routing with Redis caching
  - api_outbound.lua: API Calling product outbound calls with tier-aware CPS
  - trunk_outbound.lua: SIP Trunk customer outbound calls
-->
<include>

  <!-- ============================================ -->
  <!-- DEFAULT CONTEXT - Registered Users          -->
  <!-- ============================================ -->
  <!--
    This context handles calls FROM registered users (Zoiper, etc.)
    Allows local extension dialing and test RCF calls
  -->
  <context name="default">

    <!-- ============================================ -->
    <!-- MULTI-TENANT LOCAL EXTENSION DIALING         -->
    <!-- ============================================ -->
    <!--
      When a registered UCaaS user dials another extension, we must route
      within their customer namespace.  The variable ${customer_domain} is
      set during registration by mod_xml_curl (e.g., customer_5.voiceplatform.local).
      If not set, we fall back to $${domain} for legacy test extensions.
    -->

    <!-- Local extension dialing: short codes 2-6 digits (multi-tenant) -->
    <!-- Matches any 2-6 digit extension within the caller's customer domain -->
    <extension name="local_extension">
      <condition field="destination_number" expression="^(\d{2,6})$">
        <action application="log" data="INFO Local extension call: ${caller_id_number} -> $1 (domain=${customer_domain:-$${domain}})"/>
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="call_timeout=30"/>
        <action application="set" data="continue_on_fail=true"/>
        <!-- Set the dialed extension for voicemail fallback -->
        <action application="set" data="dialed_extension=$1"/>
        <!-- Resolve the target domain: customer_domain from registration, or legacy fallback -->
        <action application="set" data="target_domain=${customer_domain:-$${domain}}"/>
        <!-- Ring the called extension in the caller's customer domain -->
        <action application="bridge" data="user/$1@${target_domain}"/>
        <!-- If no answer, busy, or not registered: send to voicemail -->
        <action application="log" data="INFO Extension $1 unavailable, sending to voicemail"/>
        <action application="answer"/>
        <action application="sleep" data="1000"/>
        <action application="voicemail" data="default ${target_domain} ${dialed_extension}"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- VOICEMAIL CHECK (*97)                       -->
    <!-- ============================================ -->
    <!-- Registered users dial *97 to check their own voicemail -->
    <extension name="voicemail_check">
      <condition field="destination_number" expression="^\*97$">
        <action application="log" data="INFO Voicemail check: ${caller_id_number} (domain=${customer_domain:-$${domain}})"/>
        <action application="set" data="target_domain=${customer_domain:-$${domain}}"/>
        <action application="answer"/>
        <action application="sleep" data="1000"/>
        <action application="voicemail" data="check default ${target_domain} ${caller_id_number}"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- CONFERENCE ROOMS (*88XX)                    -->
    <!-- ============================================ -->
    <!-- Dial *8801 to join conference room 01, *8802 for room 02, etc. -->
    <extension name="conference_room">
      <condition field="destination_number" expression="^\*88(\d{2})$">
        <action application="log" data="INFO Conference join: ${caller_id_number} -> room $1"/>
        <action application="answer"/>
        <action application="conference" data="room_$1@default"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- VALET PARKING (*58XX park, *59XX retrieve)  -->
    <!-- ============================================ -->
    <!-- Dial *5801 to park a call in slot 01, *5901 to retrieve it -->
    <extension name="valet_park">
      <condition field="destination_number" expression="^\*58(\d{2})$">
        <action application="log" data="INFO Valet park: ${caller_id_number} -> slot $1"/>
        <action application="answer"/>
        <action application="valet_park" data="valet_lot $1"/>
      </condition>
    </extension>

    <extension name="valet_unpark">
      <condition field="destination_number" expression="^\*59(\d{2})$">
        <action application="log" data="INFO Valet retrieve: ${caller_id_number} -> slot $1"/>
        <action application="answer"/>
        <action application="valet_park" data="valet_lot $1"/>
      </condition>
    </extension>

    <!-- Test RCF DIDs: 555XXXX pattern -->
    <!-- Routes through Lua for dynamic RCF lookup -->
    <extension name="test_rcf_did">
      <condition field="destination_number" expression="^(555\d{4})$">
        <action application="log" data="INFO Test RCF call: ${caller_id_number} -> $1"/>
        <action application="set" data="direction=inbound"/>
        <action application="set" data="call_start_time=${strftime(%Y-%m-%d %H:%M:%S)}"/>
        <action application="set" data="is_local_test=true"/>
        <!-- Transfer to public context for Lua-based RCF routing -->
        <action application="transfer" data="$1 XML public"/>
      </condition>
    </extension>

    <!-- Echo test for registered users -->
    <extension name="echo_test_default">
      <condition field="destination_number" expression="^9196$">
        <action application="answer"/>
        <action application="echo"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- OUTBOUND PSTN via Kamailio SBC / Bandwidth  -->
    <!-- ============================================ -->
    <!--
      Verto/WebRTC users dial PSTN numbers. We normalize to E.164,
      bridge through the external profile (public IP in SDP/Via/Contact)
      to Kamailio SBC on 127.0.0.1:5060. X-Carrier header selects
      the Bandwidth trunk: standard (Dallas) or premium (LA) failover.
    -->
    <extension name="default_outbound">
      <!-- Match 10-digit, 11-digit (1+10), or +1 prefixed numbers -->
      <condition field="destination_number" expression="^(\+?1?)(\d{10})$">
        <action application="log" data="INFO PSTN outbound: ${caller_id_number} -> +1$2 (raw: $0)"/>

        <!-- Normalize destination to E.164 -->
        <action application="set" data="e164_dest=+1$2"/>

        <!-- Call control settings -->
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="continue_on_fail=true"/>
        <action application="set" data="direction=outbound"/>
        <action application="set" data="call_start_time=${strftime(%Y-%m-%d %H:%M:%S)}"/>

        <!-- Look up the user's assigned DID for outbound caller ID.
             Extension numbers like "1001" are rejected by the carrier because
             they are not provisioned DIDs. The Lua script queries the extensions
             table for the user's assigned_did and falls back to the platform
             default DID (+17743260301) if none is assigned. -->
        <action application="lua" data="lookup_user_did.lua"/>

        <!-- Primary: Bandwidth Dallas via Kamailio -->
        <action application="set" data="sip_h_X-Carrier=standard"/>
        <action application="bridge" data="sofia/external/${e164_dest}@127.0.0.1:5060"/>

        <!-- Failover: Bandwidth LA via Kamailio -->
        <action application="log" data="WARNING PSTN primary failed (${bridge_hangup_cause}), trying premium carrier"/>
        <action application="set" data="sip_h_X-Carrier=premium"/>
        <action application="bridge" data="sofia/external/${e164_dest}@127.0.0.1:5060"/>

        <!-- Both carriers failed -->
        <action application="log" data="ERR PSTN outbound failed on all carriers: ${caller_id_number} -> ${e164_dest} cause=${bridge_hangup_cause}"/>
        <action application="playback" data="ivr/ivr-call_cannot_be_completed_as_dialed.wav"/>
        <action application="hangup" data="NORMAL_TEMPORARY_FAILURE"/>
      </condition>
    </extension>

    <!-- Catchall for unmatched in default context -->
    <extension name="default_catchall">
      <condition field="destination_number" expression=".*">
        <action application="log" data="WARNING Unmatched in default context: ${destination_number}"/>
        <action application="playback" data="tone_stream://%(200,100,400,450);%(200,100,400,450);%(200,100,400,450)"/>
        <action application="hangup" data="NO_ROUTE_DESTINATION"/>
      </condition>
    </extension>

  </context>

  <!-- ============================================ -->
  <!-- PUBLIC CONTEXT - Carrier/External Traffic   -->
  <!-- ============================================ -->
  <context name="public">

    <!-- ============================================ -->
    <!-- ANTI-FRAUD: Block known attack patterns     -->
    <!-- ============================================ -->

    <!-- Block empty destinations (scanner behavior) -->
    <extension name="block_empty_dest" continue="false">
      <condition field="destination_number" expression="^$">
        <action application="log" data="WARNING Blocked empty destination from ${sip_from_uri}"/>
        <action application="respond" data="404 Not Found"/>
      </condition>
    </extension>

    <!-- Block SIP URIs with @ (potential injection) -->
    <extension name="block_uri_injection" continue="false">
      <condition field="destination_number" expression="@">
        <action application="log" data="WARNING Blocked URI injection attempt: ${destination_number}"/>
        <action application="respond" data="403 Forbidden"/>
      </condition>
    </extension>

    <!-- Block obviously invalid destinations (non-digits except +) -->
    <extension name="block_invalid_chars" continue="false">
      <condition field="destination_number" expression="[^0-9+*#]">
        <action application="log" data="WARNING Blocked invalid characters in destination: ${destination_number}"/>
        <action application="respond" data="404 Not Found"/>
      </condition>
    </extension>

    <!-- Block excessively long destinations (>20 digits) -->
    <extension name="block_long_dest" continue="false">
      <condition field="destination_number" expression="^.{21,}$">
        <action application="log" data="WARNING Blocked excessive length destination: ${destination_number}"/>
        <action application="respond" data="404 Not Found"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- SPECIAL NUMBERS (Testing/Admin)            -->
    <!-- ============================================ -->

    <!-- Echo test (for carrier/audio verification) -->
    <extension name="echo_test">
      <condition field="destination_number" expression="^9196$">
        <action application="answer"/>
        <action application="echo"/>
      </condition>
    </extension>

    <!-- Delay echo (test for latency) -->
    <extension name="delay_echo">
      <condition field="destination_number" expression="^9195$">
        <action application="answer"/>
        <action application="delay_echo" data="5000"/>
      </condition>
    </extension>

    <!-- Tone test (DTMF verification) -->
    <extension name="tone_test">
      <condition field="destination_number" expression="^9198$">
        <action application="answer"/>
        <action application="playback" data="tone_stream://%(500,500,440,480)"/>
        <action application="sleep" data="5000"/>
        <action application="hangup"/>
      </condition>
    </extension>

    <!-- Milliwatt test (audio level verification) -->
    <extension name="milliwatt">
      <condition field="destination_number" expression="^9197$">
        <action application="answer"/>
        <action application="playback" data="tone_stream://%(10000,0,1000);loops=-1"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- LOCAL EXTENSION DIALING (Registered Users) -->
    <!-- ============================================ -->
    <!--
      Allows registered users to call each other by extension.
      Multi-tenant: uses the caller's customer_domain so extensions
      are resolved within the correct customer namespace.
      Falls back to $${domain} for legacy test extensions (1001-1003).

      SECURITY: This only works for registered users because:
      - External carriers don't send short-digit numbers
      - The bridge uses user/ which requires registration lookup
    -->
    <extension name="local_extension_public">
      <condition field="destination_number" expression="^(\d{2,6})$">
        <action application="log" data="INFO Local extension call (public): ${caller_id_number} -> $1 (domain=${customer_domain:-$${domain}})"/>
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="call_timeout=30"/>
        <action application="set" data="continue_on_fail=true"/>
        <action application="set" data="dialed_extension=$1"/>
        <action application="set" data="target_domain=${customer_domain:-$${domain}}"/>
        <!-- Ring the called extension in the caller's customer domain -->
        <action application="bridge" data="user/$1@${target_domain}"/>
        <!-- If no answer, busy, or not registered: send to voicemail -->
        <action application="log" data="INFO Extension $1 unavailable, sending to voicemail"/>
        <action application="answer"/>
        <action application="sleep" data="1000"/>
        <action application="voicemail" data="default ${target_domain} ${dialed_extension}"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- OUTBOUND API CALLS (Originated via ESL)    -->
    <!-- ============================================ -->
    <!--
      Calls originated via Event Socket for API Calling product
      These have outbound_api=true set by the originate command
      Uses api_outbound.lua with tier-aware CPS limits (25/50/100+ CPS)
    -->
    <extension name="outbound_api">
      <condition field="${outbound_api}" expression="^true$">
        <action application="log" data="INFO API Outbound: ${uuid} to ${destination_number} customer=${customer_id}"/>
        <action application="set" data="direction=outbound"/>
        <action application="set" data="product_type=api"/>
        <action application="set" data="call_start_time=${strftime(%Y-%m-%d %H:%M:%S)}"/>

        <!-- Set hangup hook for cleanup -->
        <action application="set" data="api_on_answer="/>
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="continue_on_fail=false"/>

        <!-- Execute Lua script for API call handling with tier-aware CPS -->
        <action application="lua" data="api_outbound.lua"/>

        <!-- Fallback if Lua doesn't handle -->
        <action application="log" data="ERR API Outbound script did not complete call"/>
        <action application="hangup" data="NORMAL_TEMPORARY_FAILURE"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- OUTBOUND API CALLS (product_type routing)   -->
    <!-- ============================================ -->
    <!--
      Alternative routing for API calls based on product_type variable
      This handles cases where calls are transferred to API processing
    -->
    <extension name="api_product_type">
      <condition field="${product_type}" expression="^api$">
        <condition field="${direction}" expression="^outbound$">
          <action application="log" data="INFO API Product Type Route: ${uuid} to ${destination_number}"/>
          <action application="set" data="call_start_time=${strftime(%Y-%m-%d %H:%M:%S)}"/>

          <!-- Execute API outbound script with tier enforcement -->
          <action application="lua" data="api_outbound.lua"/>

          <!-- Fallback -->
          <action application="log" data="ERR API product_type route did not complete"/>
          <action application="hangup" data="NORMAL_TEMPORARY_FAILURE"/>
        </condition>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- TRUNK OUTBOUND (From Customer PBX)         -->
    <!-- ============================================ -->
    <!--
      Calls from authenticated SIP trunk customers.
      Kamailio authenticates the customer by source IP and sets:
        X-Trunk-ID: trunk database ID
        X-Customer-ID: customer database ID
        X-Max-Channels: max concurrent channels for this trunk
      FreeSWITCH exposes these as ${sip_h_X-Trunk-ID}, etc.

      This extension fires BEFORE the inbound handler so trunk
      outbound calls don't accidentally match as inbound DIDs.
    -->
    <!-- Debug: Log all X-Trunk header variants to find the right variable name -->
    <extension name="trunk_header_debug" continue="true">
      <condition field="destination_number" expression="^(.*)$">
        <action application="log" data="DEBUG TRUNK-HEADER-CHECK: X-Trunk-ID=[${sip_h_X-Trunk-ID}] X_Trunk_ID=[${sip_h_X_Trunk_ID}] X-Trunk-Id=[${sip_h_X-Trunk-Id}]"/>
      </condition>
    </extension>

    <extension name="trunk_outbound_from_kamailio">
      <condition field="${sip_h_X-Trunk-ID}" expression="^\s*\d+\s*$">
        <action application="log" data="INFO Trunk Outbound (Kamailio-auth): trunk=${sip_h_X-Trunk-ID} customer=${sip_h_X-Customer-ID} to ${destination_number}"/>

        <!-- Copy SIP headers to channel variables for Lua script access -->
        <action application="set" data="trunk_id=${sip_h_X-Trunk-ID}"/>
        <action application="set" data="customer_id=${sip_h_X-Customer-ID}"/>
        <action application="set" data="max_channels=${sip_h_X-Max-Channels}"/>
        <action application="set" data="direction=outbound"/>
        <action application="set" data="product_type=trunk"/>
        <action application="set" data="call_start_time=${strftime(%Y-%m-%d %H:%M:%S)}"/>

        <!-- Execute Lua script for trunk call handling -->
        <action application="lua" data="trunk_outbound.lua"/>

        <!-- Fallback if Lua doesn't handle -->
        <action application="log" data="ERR Trunk script did not complete call"/>
        <action application="hangup" data="NORMAL_TEMPORARY_FAILURE"/>
      </condition>
    </extension>

    <!-- Legacy trunk outbound: trunk_id set by prior dialplan logic (not Kamailio) -->
    <extension name="trunk_outbound">
      <condition field="${trunk_id}" expression="^\d+$">
        <action application="log" data="INFO Trunk Outbound (legacy): trunk=${trunk_id} to ${destination_number}"/>
        <action application="set" data="direction=outbound"/>
        <action application="set" data="product_type=trunk"/>
        <action application="set" data="call_start_time=${strftime(%Y-%m-%d %H:%M:%S)}"/>

        <!-- Execute Lua script for trunk call handling -->
        <action application="lua" data="trunk_outbound.lua"/>

        <!-- Fallback if Lua doesn't handle -->
        <action application="log" data="ERR Trunk script did not complete call"/>
        <action application="hangup" data="NORMAL_TEMPORARY_FAILURE"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- INBOUND CALLS (Main Lua-based routing)     -->
    <!-- ============================================ -->
    <!--
      All inbound calls to DIDs (RCF, API, Trunk)
      Routes through inbound_router.lua for dynamic lookup:
      1. Check Redis cache for RCF routes
      2. Query PostgreSQL for RCF/API/Trunk DID mappings
      3. Apply velocity limits and fraud checks
      4. Route to destination or webhook

      This is the primary routing mechanism for the platform.
    -->
    <extension name="inbound_handler">
      <condition field="destination_number" expression="^(\+?1?\d{10,15})$">
        <action application="log" data="INFO Inbound: ${caller_id_number} -> ${destination_number} from ${network_addr}"/>

        <!-- Set common channel variables -->
        <action application="set" data="direction=inbound"/>
        <action application="set" data="call_start_time=${strftime(%Y-%m-%d %H:%M:%S)}"/>
        <action application="set" data="sip_source_ip=${network_addr}"/>

        <!-- Execute Lua routing script -->
        <!-- inbound_router.lua handles: RCF lookup, API DID lookup, Trunk DID lookup -->
        <!-- It also handles caching, velocity limits, and fraud prevention -->
        <action application="lua" data="inbound_router.lua"/>

        <!-- Fallback if Lua script doesn't handle the call -->
        <!-- If lua_routed=true, the DID was found but the bridge failed -->
        <!-- Return 503 (not 404) so the caller knows the DID exists but service is unavailable -->
        <action application="log" data="WARNING Lua router returned without completing call for ${destination_number} (lua_routed=${lua_routed})"/>
        <action application="set" data="proto_specific_hangup_cause=sip:503"/>
        <action application="respond" data="503 Service Unavailable"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- SHORTER NUMBER FORMATS                     -->
    <!-- ============================================ -->
    <!--
      Handle 10-digit and other formats without +/1 prefix
      Normalize and route through main handler
    -->
    <extension name="inbound_short">
      <condition field="destination_number" expression="^(\d{10})$">
        <action application="log" data="INFO Inbound (short): ${caller_id_number} -> ${destination_number}"/>

        <!-- Normalize to E.164 -->
        <action application="set" data="destination_number=+1$1"/>

        <!-- Transfer to main handler -->
        <action application="transfer" data="+1$1 XML public"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- STAR CODES (Feature Access)                -->
    <!-- ============================================ -->
    <!--
      Handle star codes if needed (e.g., *67 for CLID blocking)
      Could be used for trunk customers with feature codes
    -->
    <extension name="star_codes">
      <condition field="destination_number" expression="^\*\d{2,4}$">
        <action application="log" data="INFO Star code: ${destination_number} from ${caller_id_number}"/>
        <!-- Handle star codes in Lua or reject -->
        <action application="respond" data="404 Not Found"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- EMERGENCY NUMBERS                          -->
    <!-- ============================================ -->
    <!--
      Route emergency calls through appropriate carrier
      IMPORTANT: Ensure 911 routing is properly configured and tested
    -->
    <extension name="emergency_911">
      <condition field="destination_number" expression="^(911|933)$">
        <action application="log" data="CRIT 911 CALL: from ${caller_id_number} (${sip_from_uri})"/>

        <!-- Set emergency call flags -->
        <action application="set" data="is_emergency=true"/>
        <action application="set" data="emergency_callback=${caller_id_number}"/>

        <!-- Route to emergency carrier via Kamailio proxy using external profile -->
        <!-- External profile ensures public IP in Via/Contact/SDP headers -->
        <!-- X-Carrier header tells Kamailio which Bandwidth IP to use -->
        <action application="set" data="sip_h_X-Carrier=standard"/>
        <action application="bridge" data="sofia/external/911@127.0.0.1:5060"/>

        <!-- If bridge fails, try backup -->
        <action application="set" data="sip_h_X-Carrier=premium"/>
        <action application="bridge" data="sofia/external/911@127.0.0.1:5060"/>

        <!-- Absolute last resort -->
        <action application="log" data="CRIT 911 ROUTING FAILED"/>
        <action application="playback" data="ivr/ivr-call_cannot_be_completed_as_dialed.wav"/>
        <action application="hangup" data="NETWORK_OUT_OF_ORDER"/>
      </condition>
    </extension>

    <!-- ============================================ -->
    <!-- CATCHALL - Reject Unknown                  -->
    <!-- ============================================ -->
    <!--
      Final fallback - reject anything that wasn't matched
      This should rarely be hit if dialplan is complete
    -->
    <extension name="unmatched">
      <condition field="destination_number" expression=".*">
        <action application="log" data="WARNING Unmatched call: ${caller_id_number} -> ${destination_number} from ${network_addr}"/>

        <!-- Respond with appropriate SIP error -->
        <action application="respond" data="404 Not Found"/>
      </condition>
    </extension>

  </context>

  <!-- ============================================ -->
  <!-- FEATURES CONTEXT (for transfers, etc.)      -->
  <!-- ============================================ -->
  <context name="features">
    <!-- Handle attended transfer parking, etc. -->
    <extension name="feature_default">
      <condition field="destination_number" expression=".*">
        <action application="transfer" data="${destination_number} XML public"/>
      </condition>
    </extension>
  </context>

</include>
