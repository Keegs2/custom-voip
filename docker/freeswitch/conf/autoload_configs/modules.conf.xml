<?xml version="1.0" encoding="utf-8"?>
<!--
  FreeSWITCH Module Configuration
  Optimized module selection for high-volume voice platform

  Module Categories:
  - REQUIRED: Essential for basic operation
  - RECOMMENDED: Improve functionality/performance
  - OPTIONAL: Enable for specific features

  NOTE: More modules = more memory. Load only what you need.
-->
<configuration name="modules.conf" description="Modules">
  <modules>

    <!-- ============================================ -->
    <!-- LOGGING (minimal for performance)           -->
    <!-- ============================================ -->
    <load module="mod_console"/>     <!-- Console output -->
    <load module="mod_logfile"/>     <!-- File logging -->
    <!-- <load module="mod_syslog"/> --> <!-- Uncomment for syslog integration -->

    <!-- ============================================ -->
    <!-- CODECS - REQUIRED for voice                 -->
    <!-- ============================================ -->

    <!-- Note: safarov/freeswitch image has codecs built into core -->
    <!-- G.711 (PCMU/PCMA) is built-in, no separate module needed -->

    <!-- OPUS - Modern codec (excellent quality, good for WebRTC) -->
    <load module="mod_opus"/>

    <!-- G.729 - Compressed codec -->
    <load module="mod_g729"/>

    <!-- AMR - Mobile network codec -->
    <load module="mod_amr"/>

    <!-- ============================================ -->
    <!-- DTMF/FAX HANDLING                           -->
    <!-- ============================================ -->

    <!-- SpanDSP - DTMF detection, T.38 fax -->
    <load module="mod_spandsp"/>

    <!-- ============================================ -->
    <!-- CORE DIALPLAN AND APPLICATIONS              -->
    <!-- ============================================ -->

    <!-- Essential commands -->
    <load module="mod_commands"/>
    <load module="mod_dptools"/>
    <load module="mod_dialplan_xml"/>

    <!-- Expression dialplan (alternative to XML) -->
    <!-- <load module="mod_dialplan_asterisk"/> -->

    <!-- ============================================ -->
    <!-- SIP ENDPOINT                                -->
    <!-- ============================================ -->

    <load module="mod_sofia"/>       <!-- SIP stack -->
    <load module="mod_loopback"/>    <!-- Loopback channels (for testing/routing) -->

    <!-- ============================================ -->
    <!-- SCRIPTING                                   -->
    <!-- ============================================ -->

    <!-- Lua - Primary scripting language -->
    <load module="mod_lua"/>

    <!-- JavaScript (alternative scripting) -->
    <!-- <load module="mod_v8"/> -->

    <!-- ============================================ -->
    <!-- HTTP/API INTEGRATION                        -->
    <!-- ============================================ -->

    <!-- Event Socket - Primary API interface -->
    <load module="mod_event_socket"/>

    <!-- HTTP API for webhooks -->
    <load module="mod_httapi"/>

    <!-- XML CURL for dynamic configuration -->
    <load module="mod_xml_curl"/>

    <!-- CURL for making HTTP requests -->
    <load module="mod_curl"/>

    <!-- HTTP cache for audio files -->
    <load module="mod_http_cache"/>

    <!-- ============================================ -->
    <!-- CDR / BILLING                               -->
    <!-- ============================================ -->

    <!-- CSV CDR (fast, simple) -->
    <load module="mod_cdr_csv"/>

    <!-- JSON CDR (for API/webhook posting) -->
    <load module="mod_json_cdr"/>

    <!-- SQLite CDR (lightweight database) -->
    <!-- <load module="mod_cdr_sqlite"/> -->

    <!-- PostgreSQL CDR (direct DB insert) -->
    <!-- <load module="mod_cdr_pg_csv"/> --> <!-- Requires odbc -->

    <!-- ============================================ -->
    <!-- AUDIO/MEDIA                                 -->
    <!-- ============================================ -->

    <!-- Tone generation -->
    <load module="mod_tone_stream"/>

    <!-- Audio file playback (WAV, etc.) -->
    <load module="mod_sndfile"/>

    <!-- Native file format -->
    <load module="mod_native_file"/>

    <!-- MP3/Shout streaming -->
    <load module="mod_shout"/>

    <!-- Local audio streams (MOH, etc.) -->
    <load module="mod_local_stream"/>

    <!-- Text-to-speech: Flite (offline TTS) - disabled, not built -->
    <!-- <load module="mod_flite"/> -->

    <!-- Text-to-speech: Say (number/date/time) -->
    <load module="mod_say_en"/>

    <!-- Alternative TTS engines (cloud-based) -->
    <!-- <load module="mod_tts_commandline"/> -->
    <!-- <load module="mod_unimrcp"/> --> <!-- For ASR/TTS via MRCP -->

    <!-- ============================================ -->
    <!-- CONFERENCING (for API calling product)     -->
    <!-- ============================================ -->

    <load module="mod_conference"/>

    <!-- ============================================ -->
    <!-- DATABASE                                    -->
    <!-- ============================================ -->

    <!-- In-memory database operations -->
    <load module="mod_db"/>

    <!-- In-memory hash for fast lookups -->
    <load module="mod_hash"/>

    <!-- ODBC for database connectivity -->
    <!-- <load module="mod_odbc_query"/> -->

    <!-- ============================================ -->
    <!-- VOICEMAIL                                   -->
    <!-- ============================================ -->

    <load module="mod_voicemail"/>

    <!-- ============================================ -->
    <!-- RECORDING                                   -->
    <!-- ============================================ -->

    <!-- Recording is handled by mod_dptools (record, record_session) -->
    <!-- No additional module needed for basic recording -->

    <!-- ============================================ -->
    <!-- OPTIONAL: Advanced Features                 -->
    <!-- ============================================ -->

    <!-- RTMP for Flash (deprecated) -->
    <!-- <load module="mod_rtmp"/> -->

    <!-- SIP REFER handling -->
    <!-- <load module="mod_sofia" data="refer"/> --> <!-- Built into mod_sofia -->

    <!-- Video transcoding (requires GPU) -->
    <!-- <load module="mod_av"/> -->

    <!-- WebRTC (Verto signaling + RTC endpoint) -->
    <load module="mod_rtc"/>
    <load module="mod_verto"/>

    <!-- Call Parking -->
    <load module="mod_valet_parking"/>

    <!-- ============================================ -->
    <!-- MONITORING                                  -->
    <!-- ============================================ -->

    <!-- SNMP monitoring -->
    <!-- <load module="mod_snmp"/> -->

    <!-- Prometheus metrics (if available) -->
    <!-- <load module="mod_prometheus"/> -->

    <!-- Event multicast -->
    <!-- <load module="mod_event_multicast"/> -->

  </modules>
</configuration>
