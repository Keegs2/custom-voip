<?xml version="1.0" encoding="utf-8"?>
<!--
  DEPRECATED: Layout definitions have been moved into conference.conf.xml.

  mod_conference parses layouts and groups in a single pass within the
  conference.conf configuration section. When layouts lived in this separate
  file (conference_layouts.conf), the group parser could not resolve layout
  names during group parsing, producing "invalid group member" errors:

    conference_video.c:327 invalid group member 1
    conference_video.c:327 invalid group member 2
    mod_conference.c:3368 Invalid video-layout-name specified, using group:grid

  The fix is to keep <layout-settings> inside <configuration name="conference.conf">
  so that layout definitions are already in the hash table when groups are parsed.

  This file is intentionally empty. It can be deleted, but is kept to document
  the issue and prevent re-introduction of the bug.
-->
<configuration name="conference_layouts.conf" description="Deprecated - layouts moved to conference.conf.xml">
</configuration>
