<?xml version="1.0" encoding="utf-8"?>
<!--
  mod_conference Configuration - Multi-Tenant Conference Rooms

  Profiles:
  - "default": Audio-only conferences (lower resource usage)
  - "video": Video-enabled conferences (passthrough mode, active speaker)

  Caller Controls:
  - 0: Mute/unmute self
  - *: Deaf + mute (privacy mode)
  - 1/2/3: Decrease/reset/increase talk volume
  - 4/5/6: Decrease/reset/increase listen volume
  - 7/8/9: Decrease/reset/increase energy threshold
  - #: Hang up

  Multi-Tenant Isolation:
  Conference rooms are namespaced by customer_id in the dialplan
  (e.g., room_5_01@video), ensuring complete tenant isolation.

  PIN Protection:
  PIN entry is handled in the dialplan via conference flags,
  not in this configuration file. See public.xml conference extension.
-->
<configuration name="conference.conf" description="Conference Configuration">
  <advertise />

  <caller-controls>
    <group name="default">
      <control action="mute" digits="0"/>
      <control action="deaf mute" digits="*"/>
      <control action="energy up" digits="9"/>
      <control action="energy equ" digits="8"/>
      <control action="energy dn" digits="7"/>
      <control action="vol talk up" digits="3"/>
      <control action="vol talk zero" digits="2"/>
      <control action="vol talk dn" digits="1"/>
      <control action="vol listen up" digits="6"/>
      <control action="vol listen zero" digits="5"/>
      <control action="vol listen dn" digits="4"/>
      <control action="hangup" digits="#"/>
    </group>
  </caller-controls>

  <profiles>
    <!-- Audio-only conference profile -->
    <profile name="default">
      <param name="domain" value="$${domain}"/>
      <param name="rate" value="48000"/>
      <param name="interval" value="20"/>
      <param name="energy-level" value="100"/>
      <param name="caller-controls" value="default"/>
      <param name="muted-sound" value="conference/conf-muted.wav"/>
      <param name="unmuted-sound" value="conference/conf-unmuted.wav"/>
      <param name="alone-sound" value="conference/conf-alone.wav"/>
      <param name="enter-sound" value="tone_stream://%(200,0,500,600,700)"/>
      <param name="exit-sound" value="tone_stream://%(500,0,300,200,100,50,25)"/>
      <param name="max-members" value="50"/>
      <param name="comfort-noise" value="true"/>
    </profile>

    <!--
      Video-enabled conference profile
      Uses passthrough mode: each participant receives the active speaker's
      video stream directly. No server-side compositing, no canvas, no
      layout resolution needed. Low CPU, works reliably.

      video-mode options:
        - mux: Server-side compositing (requires working mod_av + layout resolution)
        - passthrough: Forward active speaker's video only (low CPU, reliable)
        - transcode: Full transcoding between codecs

      NOTE: mux mode with group:grid layouts is defined below in <layout-settings>
      but disabled for now. The layout group resolution fails on this FreeSWITCH
      build (mod_conference cannot resolve "group:grid" even with correct XML).
      Re-enable mux mode once mod_av video compositing is confirmed working.

      IMPORTANT: The conference app answers the Verto channel internally.
      Do NOT add an explicit answer app in the dialplan before conference,
      as it blocks forever on Verto/WebRTC channels (answer waits for ICE
      completion, which requires the SDP answer, creating a deadlock when
      the conference hasn't initialized the video canvas yet).
    -->
    <profile name="video">
      <param name="domain" value="$${domain}"/>
      <param name="codec-string" value="opus,VP8"/>
      <param name="rate" value="48000"/>
      <param name="interval" value="20"/>
      <param name="energy-level" value="100"/>
      <param name="caller-controls" value="default"/>
      <param name="enter-sound" value="tone_stream://%(200,0,500,600,700)"/>
      <param name="exit-sound" value="tone_stream://%(500,0,300,200,100,50,25)"/>
      <param name="max-members" value="50"/>
      <param name="comfort-noise" value="true"/>
      <!-- Video: mux mode — composites all video streams and mixes all audio.
           Passthrough mode only forwards floor holder's video and can strip
           speak flags from non-floor members, causing one-way audio. Mux mode
           ensures all participants can both see and hear each other. -->
      <param name="video-mode" value="mux"/>
      <param name="video-codec-bandwidth" value="2mb"/>
      <param name="video-fps" value="30"/>
      <param name="video-canvas-size" value="1280x720"/>
      <param name="video-canvas-bgcolor" value="#0f1117"/>
      <param name="video-layout-name" value="group:grid"/>
      <param name="video-auto-floor" value="true"/>
    </profile>
  </profiles>

  <!--
    Video Layouts - Retained for future video-mode="mux" support

    NOT CURRENTLY USED. The video profile uses passthrough mode, which does
    not require layout definitions. These are kept here so that switching
    back to mux mode only requires changing the profile params above:
      video-mode=mux, video-layout-name=group:grid, video-canvas-size=1920x1080,
      video-canvas-bgcolor=#333333, video-layout-bgcolor=#000000

    These layouts define how participant video streams are composited onto the
    shared canvas. The "group:grid" layout-name auto-selects the best grid
    layout based on the number of participants.

    IMPORTANT: Layout definitions MUST live inside conference.conf, not in a
    separate conference_layouts.conf file. mod_conference parses layouts and
    groups in a single pass within the same configuration section.

    Canvas coordinate system:
      x, y: top-left corner of the participant's rectangle (0,0 = top-left of canvas)
      scale: fraction of canvas width (e.g., 360 on a 720-wide canvas = 0.5)
      All values are relative to the canvas size (1920x1080 when mux is enabled).
  -->
  <layout-settings>
    <layouts>

      <!-- Single participant: full canvas -->
      <layout name="1up_top" auto-3d-position="true">
        <image x="0" y="0" scale="720" reservation_id="presenter" />
      </layout>

      <!-- Two participants: side by side -->
      <layout name="2up" auto-3d-position="true">
        <image x="0" y="90" scale="360" />
        <image x="360" y="90" scale="360" />
      </layout>

      <!-- Three participants: one on top, two on bottom -->
      <layout name="3up" auto-3d-position="true">
        <image x="180" y="0" scale="360" />
        <image x="0" y="180" scale="360" />
        <image x="360" y="180" scale="360" />
      </layout>

      <!-- Four participants: 2x2 grid -->
      <layout name="4up" auto-3d-position="true">
        <image x="0" y="0" scale="360" />
        <image x="360" y="0" scale="360" />
        <image x="0" y="180" scale="360" />
        <image x="360" y="180" scale="360" />
      </layout>

      <!-- Six participants: 3x2 grid -->
      <layout name="6up" auto-3d-position="true">
        <image x="0" y="0" scale="240" />
        <image x="240" y="0" scale="240" />
        <image x="480" y="0" scale="240" />
        <image x="0" y="180" scale="240" />
        <image x="240" y="180" scale="240" />
        <image x="480" y="180" scale="240" />
      </layout>

      <!-- Nine participants: 3x3 grid -->
      <layout name="9up" auto-3d-position="true">
        <image x="0" y="0" scale="240" />
        <image x="240" y="0" scale="240" />
        <image x="480" y="0" scale="240" />
        <image x="0" y="120" scale="240" />
        <image x="240" y="120" scale="240" />
        <image x="480" y="120" scale="240" />
        <image x="0" y="240" scale="240" />
        <image x="240" y="240" scale="240" />
        <image x="480" y="240" scale="240" />
      </layout>

      <!-- Presenter + gallery: large active speaker with 4 small thumbnails -->
      <layout name="presenter" auto-3d-position="true">
        <image x="0" y="0" scale="540" reservation_id="presenter" floor="true" />
        <image x="540" y="0" scale="180" />
        <image x="540" y="90" scale="180" />
        <image x="540" y="180" scale="180" />
        <image x="540" y="270" scale="180" />
      </layout>

    </layouts>

    <!-- Layout group: auto-selects layout based on participant count -->
    <!-- Referenced by video-layout-name="group:grid" in the video profile above -->
    <groups>
      <group name="grid">
        <layout name="1up_top">1</layout>
        <layout name="2up">2</layout>
        <layout name="3up">3</layout>
        <layout name="4up">4</layout>
        <layout name="6up">6</layout>
        <layout name="9up">9</layout>
      </group>
    </groups>

  </layout-settings>
</configuration>
