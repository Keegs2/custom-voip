<?xml version="1.0" encoding="utf-8"?>
<!--
  Internal SIP Profile - Optimized for High Volume Voice Platform
  This profile receives traffic from Kamailio SBC and handles:
  - RCF (Remote Call Forwarding) calls
  - API Calling product calls
  - SIP Trunk customer calls
  - LOCAL TESTING: Zoiper softphone registration (extensions 1001-1003)

  Design Notes:
  - Traffic comes from Kamailio (trusted) on port 5080
  - Outbound to carriers via gateways
  - NAT handling done at Kamailio layer
  - For local testing: Zoiper can register on port 5080 with digest auth
-->
<profile name="internal">
  <settings>
    <!-- ============================================ -->
    <!-- NETWORK CONFIGURATION                       -->
    <!-- ============================================ -->

    <!-- Local IP binding -->
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="sip-port" value="$${internal_sip_port}"/>

    <!-- RTP binding -->
    <param name="rtp-ip" value="$${local_ip_v4}"/>

    <!-- External IP for SDP (set to public IP in production) -->
    <!-- In Docker: use host IP or configure ext-rtp-ip via env var -->
    <param name="ext-rtp-ip" value="auto-nat"/>
    <param name="ext-sip-ip" value="auto-nat"/>

    <!-- Force external IP if behind NAT (uncomment and set in production) -->
    <!-- <param name="ext-rtp-ip" value="$${external_ip}"/> -->
    <!-- <param name="ext-sip-ip" value="$${external_ip}"/> -->

    <!-- ============================================ -->
    <!-- TLS CONFIGURATION                           -->
    <!-- ============================================ -->

    <!-- TLS disabled for MVP (no openssl in base image) -->
    <!-- To enable TLS: -->
    <!-- 1. Mount certificates to /etc/freeswitch/tls -->
    <!-- 2. Change tls value to "true" -->
    <param name="tls" value="false"/>
    <!-- <param name="tls-sip-port" value="$${internal_tls_port}"/> -->
    <!-- <param name="tls-cert-dir" value="/etc/freeswitch/tls"/> -->
    <!-- <param name="tls-version" value="tlsv1.2"/> -->
    <!-- <param name="tls-ciphers" value="HIGH:!aNULL:!MD5:!3DES"/> -->
    <!-- For mTLS with carriers (uncomment when ready) -->
    <!-- <param name="tls-verify-policy" value="subjects_all"/> -->
    <!-- <param name="tls-verify-depth" value="2"/> -->

    <!-- ============================================ -->
    <!-- DIALPLAN CONFIGURATION                      -->
    <!-- ============================================ -->

    <!-- All calls enter the public context -->
    <!-- Public context handles: -->
    <!--   - Anti-fraud rules (first) -->
    <!--   - Local extension dialing for registered users (10XX) -->
    <!--   - Inbound DID routing (RCF, API, Trunk) -->
    <param name="context" value="public"/>
    <param name="dialplan" value="XML"/>

    <!-- ============================================ -->
    <!-- CODEC CONFIGURATION                         -->
    <!-- ============================================ -->

    <!-- Codec preference order (PSTN-optimized) -->
    <!-- G.711 is most compatible with carriers -->
    <param name="inbound-codec-prefs" value="PCMU,PCMA,G722,opus"/>
    <param name="outbound-codec-prefs" value="PCMU,PCMA,G722,opus"/>

    <!-- Greedy codec negotiation - prefer our list over remote -->
    <param name="inbound-codec-negotiation" value="greedy"/>

    <!-- Late codec negotiation for transcoding scenarios -->
    <param name="inbound-late-negotiation" value="true"/>

    <!-- ============================================ -->
    <!-- DTMF CONFIGURATION                          -->
    <!-- ============================================ -->

    <param name="dtmf-type" value="rfc2833"/>
    <param name="dtmf-duration" value="2000"/>
    <param name="rfc2833-pt" value="101"/>

    <!-- Liberal DTMF handling for carrier compatibility -->
    <param name="liberal-dtmf" value="true"/>
    <param name="pass-rfc2833" value="true"/>

    <!-- ============================================ -->
    <!-- SIP TIMER CONFIGURATION                     -->
    <!-- Tuned for carrier interconnect              -->
    <!-- ============================================ -->

    <!-- T1 timer - RTT estimate (500ms default) -->
    <param name="sip-timer-T1" value="500"/>

    <!-- T2 timer - max retransmit interval (4000ms default) -->
    <param name="sip-timer-T2" value="4000"/>

    <!-- T4 timer - max message lifetime (4000ms) -->
    <param name="sip-timer-T4" value="4000"/>

    <!-- Session expires (RFC 4028) -->
    <param name="sip-session-timeout" value="1800"/>
    <param name="sip-min-session-expires" value="90"/>

    <!-- Force session timer refresh (good for long calls) -->
    <param name="enable-timer" value="true"/>
    <param name="minimum-session-expires" value="90"/>

    <!-- ============================================ -->
    <!-- HIGH VOLUME OPTIMIZATIONS                   -->
    <!-- ============================================ -->

    <!-- Use Call-ID as UUID (reduces memory/lookup overhead) -->
    <param name="inbound-use-callid-as-uuid" value="true"/>

    <!-- Disable call tracking (we track in Lua/Redis) -->
    <param name="track-calls" value="false"/>

    <!-- Disable presence (not needed for B2BUA) -->
    <param name="manage-presence" value="false"/>

    <!-- Compact SIP headers to reduce bandwidth -->
    <param name="enable-compact-headers" value="true"/>

    <!-- Maximum concurrent sessions in PROCEEDING state -->
    <!-- Prevents resource exhaustion from incomplete calls -->
    <param name="max-proceeding" value="5000"/>

    <!-- Connection reuse for TCP/TLS (critical for performance) -->
    <param name="reuse-connections" value="true"/>

    <!-- Aggressive session cleanup -->
    <param name="nonce-ttl" value="60"/>

    <!-- ============================================ -->
    <!-- AUTHENTICATION / SECURITY                   -->
    <!-- ============================================ -->

    <!-- ACL-based authentication (traffic from Kamailio is trusted) -->
    <param name="apply-inbound-acl" value="trusted"/>

    <!-- Enable SIP digest auth for REGISTER and INVITE from local test clients -->
    <!-- This allows Zoiper softphones to register while still accepting trusted traffic -->
    <param name="auth-calls" value="true"/>
    <param name="auth-all-packets" value="false"/>

    <!-- Accept registrations for local testing -->
    <param name="accept-blind-reg" value="false"/>
    <param name="accept-blind-auth" value="false"/>

    <!-- Challenge realm for digest auth -->
    <param name="challenge-realm" value="voiceplatform.local"/>

    <!-- Log authentication attempts for debugging -->
    <param name="log-auth-failures" value="true"/>

    <!-- ============================================ -->
    <!-- DOMAIN NORMALIZATION                        -->
    <!-- ============================================ -->
    <!--
      CRITICAL FIX: Force all registrations to use consistent domain

      Problem: Clients register with different domains based on how they connect:
        - Zoiper Mac -> 1001@127.0.0.1 (localhost)
        - Zoiper iPhone -> 1003@192.168.1.158 (Mac's IP)
        - Production -> user@voiceplatform.local

      When dialplan uses user/1001@$${domain}, it expands to user/1001@voiceplatform.local
      but sofia_contact looks up 1001@voiceplatform.local which doesn't match 1001@127.0.0.1
      Result: 480 Temporarily Unavailable

      Solution: Force all registrations to be stored under $${domain}
      This makes sofia_contact work correctly regardless of client's domain
    -->

    <!-- Force registration domain: Store all registrations under this domain -->
    <param name="force-register-domain" value="$${domain}"/>

    <!-- Force database domain: Ensures sofia_contact lookups work correctly -->
    <param name="force-register-db-domain" value="$${domain}"/>

    <!-- Force subscription domain: Ensures presence/BLF works consistently -->
    <param name="force-subscription-domain" value="$${domain}"/>

    <!-- ============================================ -->
    <!-- NAT HANDLING                                -->
    <!-- ============================================ -->

    <!-- NAT detection - enabled for local Zoiper testing -->
    <param name="aggressive-nat-detection" value="true"/>
    <param name="NDLB-force-rport" value="true"/>

    <!-- Force symmetric RTP (helps with NAT) -->
    <param name="rtp-autofix-timing" value="true"/>

    <!-- NDLB settings for better NAT compatibility -->
    <param name="NDLB-received-in-nat-reg-contact" value="true"/>

    <!-- ============================================ -->
    <!-- MEDIA HANDLING                              -->
    <!-- ============================================ -->

    <!-- RTP timeout - hang up if no media -->
    <param name="rtp-timeout-sec" value="60"/>
    <param name="rtp-hold-timeout-sec" value="1800"/>

    <!-- Media options -->
    <param name="media-option" value="bypass-media-after-att-xfer"/>
    <param name="disable-hold" value="false"/>

    <!-- SRTP settings (enable for secure media) -->
    <!-- For carriers that support SRTP -->
    <param name="rtp-secure-media" value="optional"/>
    <param name="rtp-secure-media-prefer-avp" value="true"/>

    <!-- ============================================ -->
    <!-- SIP OPTIONS / FEATURES                      -->
    <!-- ============================================ -->

    <!-- User-Agent header -->
    <param name="user-agent-string" value="VoicePlatform/1.0"/>

    <!-- Enable 100rel (PRACK) for early media -->
    <param name="enable-100rel" value="true"/>

    <!-- Pass caller ID through -->
    <param name="caller-id-type" value="pid"/>

    <!-- RFC compliance -->
    <param name="rfc2833-send-payload" value="101"/>
    <param name="suppress-cng" value="true"/>

    <!-- Hold music (will be overridden by dialplan if needed) -->
    <param name="hold-music" value="silence_stream://-1"/>

  </settings>

  <!-- ============================================ -->
  <!-- CARRIER GATEWAYS                            -->
  <!-- ============================================ -->
  <gateways>
    <!--
      Standard Traffic Gateway (Primary Carrier)
      Used for: standard traffic grade calls, RCF, API calling

      CONFIGURE THESE WITH YOUR CARRIER CREDENTIALS:
      - Replace proxy with carrier SIP proxy address
      - Set realm to carrier's authentication realm
      - Set username/password for SIP auth (or remove for IP auth)
      - Add carrier's IP to ACL if using IP auth
    -->
    <gateway name="carrier_standard">
      <!-- Carrier SIP proxy -->
      <param name="proxy" value="sip.carrier-standard.example.com"/>
      <param name="realm" value="carrier-standard.example.com"/>

      <!-- Authentication (comment out for IP-based auth) -->
      <param name="username" value="voiceplatform"/>
      <param name="password" value="CHANGE_ME_IN_PRODUCTION"/>

      <!-- Registration settings -->
      <param name="register" value="false"/>
      <param name="register-transport" value="udp"/>

      <!-- Caller ID handling -->
      <param name="caller-id-in-from" value="true"/>

      <!-- Retry/timeout settings -->
      <param name="retry-seconds" value="30"/>
      <param name="expire-seconds" value="3600"/>

      <!-- Channel limits (set based on carrier contract) -->
      <!-- <param name="channels" value="100"/> -->

      <!-- Codec prefs for this gateway -->
      <param name="codec-prefs" value="PCMU,PCMA"/>

      <!-- Enable/disable -->
      <param name="enabled" value="true"/>

      <!-- Gateway identifier for routing -->
      <param name="extension-in-contact" value="true"/>
    </gateway>

    <!--
      Premium Traffic Gateway (Higher Quality/Cost)
      Used for: premium traffic grade calls
    -->
    <gateway name="carrier_premium">
      <param name="proxy" value="sip.carrier-premium.example.com"/>
      <param name="realm" value="carrier-premium.example.com"/>

      <param name="username" value="voiceplatform"/>
      <param name="password" value="CHANGE_ME_IN_PRODUCTION"/>

      <param name="register" value="false"/>
      <param name="caller-id-in-from" value="true"/>
      <param name="retry-seconds" value="30"/>
      <param name="expire-seconds" value="3600"/>

      <param name="codec-prefs" value="PCMU,PCMA,G722"/>

      <param name="enabled" value="true"/>
    </gateway>

    <!--
      Backup/Overflow Gateway
      Used for: failover when primary carriers are unavailable
    -->
    <gateway name="carrier_backup">
      <param name="proxy" value="sip.carrier-backup.example.com"/>
      <param name="realm" value="carrier-backup.example.com"/>

      <param name="username" value="voiceplatform"/>
      <param name="password" value="CHANGE_ME_IN_PRODUCTION"/>

      <param name="register" value="false"/>
      <param name="caller-id-in-from" value="true"/>

      <param name="codec-prefs" value="PCMU,PCMA"/>

      <param name="enabled" value="false"/>
    </gateway>

    <!--
      Test Gateway (Loopback for testing)
      Echoes audio back for testing without carrier
    -->
    <gateway name="test_echo">
      <param name="proxy" value="$${local_ip_v4}:5080"/>
      <param name="register" value="false"/>
      <param name="enabled" value="true"/>
    </gateway>
  </gateways>

  <!-- ============================================ -->
  <!-- DOMAIN HANDLING                             -->
  <!-- ============================================ -->
  <domains>
    <!-- Accept all domain requests (B2BUA mode) -->
    <domain name="all" alias="true" parse="true"/>
  </domains>
</profile>
