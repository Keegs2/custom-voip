<?xml version="1.0" encoding="utf-8"?>
<!--
  Internal SIP Profile - Optimized for High Volume Voice Platform
  This profile receives traffic from Kamailio SBC and handles:
  - RCF (Remote Call Forwarding) calls
  - API Calling product calls
  - SIP Trunk customer calls
  - LOCAL TESTING: Zoiper softphone registration (extensions 1001-1003)

  Design Notes:
  - Traffic comes from Kamailio (trusted) on port 5080
  - Outbound carrier calls use the EXTERNAL profile (sofia/external/dest@proxy)
    which correctly applies ext-sip-ip to Via/Contact/SDP on outbound INVITEs.
    The internal profile does NOT apply ext-sip-ip to outbound calls.
  - Carrier selection is communicated via X-Carrier header to Kamailio
  - NAT handling done at Kamailio layer
  - For local testing: Zoiper can register on port 5080 with digest auth
-->
<profile name="internal">
  <settings>
    <!-- ============================================ -->
    <!-- NETWORK CONFIGURATION                       -->
    <!-- ============================================ -->

    <!-- Local IP binding -->
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="sip-port" value="$${internal_sip_port}"/>

    <!-- RTP binding -->
    <param name="rtp-ip" value="$${local_ip_v4}"/>

    <!-- External IP for SDP and SIP headers -->
    <!--
      CRITICAL: FreeSWITCH inside Docker sees its local IP as 172.28.x.x.
      auto-nat fails in Docker (resolves to the container IP, not the host's
      public IP). When FreeSWITCH originates the B-leg INVITE through Kamailio
      to Bandwidth, the Via, Contact, and SDP must show the public IP.

      ext-rtp-ip: Controls the IP in SDP c= and m= lines (where RTP goes).
      ext-sip-ip: Controls the IP in Via, Contact headers for outbound requests.

      Both are set to $${external_sip_ip} which is populated from the
      EXTERNAL_SIP_IP environment variable (defaults to auto-nat).
      In production docker-compose.yml, EXTERNAL_SIP_IP=34.74.71.32.

      Outbound carrier calls now use the EXTERNAL profile (sofia/external/)
      which correctly applies ext-sip-ip to Via, Contact, and SDP headers.
      The internal profile's ext-sip-ip is still set for any inbound
      response scenarios. Kamailio still scrubs as defense-in-depth.
    -->
    <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>
    <param name="ext-sip-ip" value="$${external_sip_ip}"/>

    <!-- ============================================ -->
    <!-- TLS CONFIGURATION                           -->
    <!-- ============================================ -->

    <!-- TLS disabled for MVP (no openssl in base image) -->
    <!-- To enable TLS: -->
    <!-- 1. Mount certificates to /etc/freeswitch/tls -->
    <!-- 2. Change tls value to "true" -->
    <param name="tls" value="false"/>
    <!-- <param name="tls-sip-port" value="$${internal_tls_port}"/> -->
    <!-- <param name="tls-cert-dir" value="/etc/freeswitch/tls"/> -->
    <!-- <param name="tls-version" value="tlsv1.2"/> -->
    <!-- <param name="tls-ciphers" value="HIGH:!aNULL:!MD5:!3DES"/> -->
    <!-- For mTLS with carriers (uncomment when ready) -->
    <!-- <param name="tls-verify-policy" value="subjects_all"/> -->
    <!-- <param name="tls-verify-depth" value="2"/> -->

    <!-- ============================================ -->
    <!-- DIALPLAN CONFIGURATION                      -->
    <!-- ============================================ -->

    <!-- All calls enter the public context -->
    <!-- Public context handles: -->
    <!--   - Anti-fraud rules (first) -->
    <!--   - Local extension dialing for registered users (10XX) -->
    <!--   - Inbound DID routing (RCF, API, Trunk) -->
    <param name="context" value="public"/>
    <param name="dialplan" value="XML"/>

    <!-- ============================================ -->
    <!-- CODEC CONFIGURATION                         -->
    <!-- ============================================ -->

    <!-- Codec preference order (PSTN-optimized) -->
    <!-- G.711 is most compatible with carriers -->
    <param name="inbound-codec-prefs" value="PCMU,PCMA,G722,opus"/>
    <param name="outbound-codec-prefs" value="PCMU,PCMA,G722,opus"/>

    <!-- Greedy codec negotiation - prefer our list over remote -->
    <param name="inbound-codec-negotiation" value="greedy"/>

    <!-- Late codec negotiation DISABLED for B2BUA/RCF call forwarding.
         With proxy_media=true (set in Lua), FreeSWITCH needs to answer
         the A-leg codec negotiation immediately so it can set up the
         media path and generate ringback. Late negotiation delays the
         SDP answer which prevents early media/ringback from flowing.
         For RCF (our primary use case), codecs are PCMU/PCMA on both
         sides so late negotiation provides no benefit. -->
    <param name="inbound-late-negotiation" value="false"/>

    <!-- ============================================ -->
    <!-- DTMF CONFIGURATION                          -->
    <!-- ============================================ -->

    <param name="dtmf-type" value="rfc2833"/>
    <param name="dtmf-duration" value="2000"/>
    <param name="rfc2833-pt" value="101"/>

    <!-- Liberal DTMF handling for carrier compatibility -->
    <param name="liberal-dtmf" value="true"/>
    <param name="pass-rfc2833" value="true"/>

    <!-- ============================================ -->
    <!-- SIP TIMER CONFIGURATION                     -->
    <!-- Tuned for carrier interconnect              -->
    <!-- ============================================ -->

    <!-- T1 timer - RTT estimate (500ms default) -->
    <param name="sip-timer-T1" value="500"/>

    <!-- T2 timer - max retransmit interval (4000ms default) -->
    <param name="sip-timer-T2" value="4000"/>

    <!-- T4 timer - max message lifetime (4000ms) -->
    <param name="sip-timer-T4" value="4000"/>

    <!-- Session expires (RFC 4028) -->
    <param name="sip-session-timeout" value="1800"/>
    <param name="sip-min-session-expires" value="90"/>

    <!-- Force session timer refresh (good for long calls) -->
    <param name="enable-timer" value="true"/>
    <param name="minimum-session-expires" value="90"/>

    <!-- ============================================ -->
    <!-- HIGH VOLUME OPTIMIZATIONS                   -->
    <!-- ============================================ -->

    <!-- Use Call-ID as UUID (reduces memory/lookup overhead) -->
    <param name="inbound-use-callid-as-uuid" value="true"/>

    <!-- Disable call tracking (we track in Lua/Redis) -->
    <param name="track-calls" value="false"/>

    <!-- Disable presence (not needed for B2BUA) -->
    <param name="manage-presence" value="false"/>

    <!-- Compact SIP headers disabled: Kamailio's header parser (remove_hf, etc.) -->
    <!-- cannot properly manipulate compact header forms (v:, f:, t:, m:, k:, u:). -->
    <!-- Full-form headers (Via:, From:, To:, Contact:, etc.) are required for -->
    <!-- correct header removal/rewriting in the SBC layer. -->
    <param name="enable-compact-headers" value="false"/>

    <!-- Maximum concurrent sessions in PROCEEDING state -->
    <!-- Prevents resource exhaustion from incomplete calls -->
    <param name="max-proceeding" value="5000"/>

    <!-- Connection reuse for TCP/TLS (critical for performance) -->
    <param name="reuse-connections" value="true"/>

    <!-- Aggressive session cleanup -->
    <param name="nonce-ttl" value="60"/>

    <!-- ============================================ -->
    <!-- AUTHENTICATION / SECURITY                   -->
    <!-- ============================================ -->

    <!-- ACL-based authentication (traffic from Kamailio is trusted) -->
    <param name="apply-inbound-acl" value="trusted"/>

    <!-- Auth disabled — Kamailio SBC handles security -->
    <!-- Zoiper local testing still works via ACL trust -->
    <param name="auth-calls" value="false"/>
    <param name="auth-all-packets" value="false"/>

    <!-- Accept registrations for local testing -->
    <param name="accept-blind-reg" value="false"/>
    <param name="accept-blind-auth" value="false"/>

    <!-- Challenge realm for digest auth -->
    <param name="challenge-realm" value="voiceplatform.local"/>

    <!-- Log authentication attempts for debugging -->
    <param name="log-auth-failures" value="true"/>

    <!-- ============================================ -->
    <!-- DOMAIN NORMALIZATION                        -->
    <!-- ============================================ -->
    <!--
      CRITICAL FIX: Force all registrations to use consistent domain

      Problem: Clients register with different domains based on how they connect:
        - Zoiper Mac -> 1001@127.0.0.1 (localhost)
        - Zoiper iPhone -> 1003@192.168.1.158 (Mac's IP)
        - Production -> user@voiceplatform.local

      When dialplan uses user/1001@$${domain}, it expands to user/1001@voiceplatform.local
      but sofia_contact looks up 1001@voiceplatform.local which doesn't match 1001@127.0.0.1
      Result: 480 Temporarily Unavailable

      Solution: Force all registrations to be stored under $${domain}
      This makes sofia_contact work correctly regardless of client's domain
    -->

    <!-- Force registration domain: Store all registrations under this domain -->
    <param name="force-register-domain" value="$${domain}"/>

    <!-- Force database domain: Ensures sofia_contact lookups work correctly -->
    <param name="force-register-db-domain" value="$${domain}"/>

    <!-- Force subscription domain: Ensures presence/BLF works consistently -->
    <param name="force-subscription-domain" value="$${domain}"/>

    <!-- ============================================ -->
    <!-- NAT HANDLING                                -->
    <!-- ============================================ -->

    <!-- NAT detection - enabled for local Zoiper testing -->
    <param name="aggressive-nat-detection" value="true"/>
    <param name="NDLB-force-rport" value="true"/>

    <!-- Force symmetric RTP (helps with NAT) -->
    <param name="rtp-autofix-timing" value="true"/>

    <!-- NDLB settings for better NAT compatibility -->
    <param name="NDLB-received-in-nat-reg-contact" value="true"/>

    <!-- ============================================ -->
    <!-- MEDIA HANDLING                              -->
    <!-- ============================================ -->

    <!-- RTP timeout - hang up if no media -->
    <param name="rtp-timeout-sec" value="60"/>
    <param name="rtp-hold-timeout-sec" value="1800"/>

    <!-- Media options -->
    <param name="media-option" value="bypass-media-after-att-xfer"/>
    <param name="disable-hold" value="false"/>

    <!-- SRTP disabled for carrier interconnect (Bandwidth uses RTP, not SRTP).
         Setting rtp-secure-media to "optional" can cause SRTP negotiation
         in SDP (m=audio ... RTP/SAVP) which confuses PSTN carriers.
         For WebRTC or TLS-capable endpoints, enable per-call via channel variable. -->
    <param name="rtp-secure-media" value="false"/>
    <param name="rtp-secure-media-prefer-avp" value="false"/>

    <!-- ============================================ -->
    <!-- SIP OPTIONS / FEATURES                      -->
    <!-- ============================================ -->

    <!-- User-Agent header -->
    <param name="user-agent-string" value="VoicePlatform/1.0"/>

    <!-- 100rel (PRACK) for early media -- set to false for carrier compatibility.
         Many PSTN carriers (including Bandwidth) do not support PRACK.
         Requiring PRACK can prevent 180/183 early media from flowing.
         FreeSWITCH will still pass through early media without 100rel. -->
    <param name="enable-100rel" value="false"/>

    <!-- Pass caller ID through -->
    <param name="caller-id-type" value="pid"/>

    <!-- RFC compliance -->
    <param name="rfc2833-send-payload" value="101"/>
    <param name="suppress-cng" value="true"/>

    <!-- Hold music (will be overridden by dialplan if needed) -->
    <param name="hold-music" value="silence_stream://-1"/>

    <!-- ============================================ -->
    <!-- HOMER SIP CAPTURE (HEP)                     -->
    <!-- ============================================ -->
    <!--
      Send copies of all SIP messages to Homer via HEP protocol.
      This gives Homer visibility into FreeSWITCH's side of each call,
      complementing the HEP feed from Kamailio (capture-id 100).
      Together they produce complete SIP ladder diagrams.

      capture-server: Homer HEP endpoint via Docker host gateway
        (Homer's port 9060 is published on the host; 172.28.0.1
        is the Docker gateway reachable from inside containers)
      sip-capture: Enable the capture agent on this profile
      capture-id: Node identifier in Homer (200 = FreeSWITCH,
        distinct from Kamailio's 100)
    -->
    <param name="capture-server" value="udp:172.28.0.1:9060;hep=3;capture_id=200"/>
    <param name="sip-capture" value="yes"/>

  </settings>

  <!-- ============================================ -->
  <!-- CARRIER GATEWAYS (DEPRECATED)               -->
  <!-- ============================================ -->
  <!--
    IMPORTANT: Carrier gateways are NO LONGER USED for outbound bridging.

    All Lua scripts and the ESL client now use sofia/external/dest@proxy
    instead of sofia/gateway/carrier/dest. This eliminates the corrupted
    Contact header (sip:gw+carrier_standard@...) and orphaned Via
    parameter fragments that the gateway bridge syntax produced.

    How outbound routing works now:
      1. FreeSWITCH bridges with: sofia/external/+17742184477@172.28.0.1:5060
         - Produces a standard INVITE with clean Via/Contact headers
         - Via and Contact use ext-sip-ip (public IP 34.74.71.32)
         - The EXTERNAL profile is used because the internal profile does
           NOT apply ext-sip-ip to outbound calls
      2. X-Carrier header tells Kamailio which Bandwidth IP to route to:
         - X-Carrier: standard -> Bandwidth Dallas 67.231.2.12
         - X-Carrier: premium  -> Bandwidth LA 216.82.238.134
         - X-Carrier: backup   -> Bandwidth Dallas 67.231.2.12 (failover)
      3. Kamailio's route[TO_CARRIER] reads X-Carrier, sets $rd/$du,
         does topology hiding, and relays to Bandwidth.

    The gateway definitions below are kept disabled for reference only.
    They document the carrier trunk configurations and Bandwidth signaling IPs.
  -->
  <gateways>
    <!--
      Bandwidth Trunk Configuration 4 - GraniteTelecommunicationsLLC_O3
      Low-CPS trunk for RCF and SIP Trunk customers. Standard carrier rates.
      Signaling: Dallas proxy 67.231.2.12:5060
      Mapped to X-Carrier: standard
    -->
    <!-- DISABLED: Outbound calls now use sofia/external/dest@proxy with X-Carrier header
    <gateway name="carrier_standard">
      <param name="proxy" value="172.28.0.1"/>
      <param name="port" value="5060"/>
      <param name="realm" value="172.28.0.1"/>
      <param name="register" value="false"/>
      <param name="caller-id-in-from" value="true"/>
      <param name="codec-prefs" value="PCMU,PCMA"/>
      <param name="enabled" value="true"/>
    </gateway>
    -->

    <!--
      Bandwidth Trunk Configuration 4 - GraniteTelecommunicationsLLC_O3
      High-CPS trunk for API Calling customers. Individually negotiated rates.
      Signaling: Los Angeles proxy 216.82.238.134:5060
      Mapped to X-Carrier: premium
    -->
    <!-- DISABLED: Outbound calls now use sofia/external/dest@proxy with X-Carrier header
    <gateway name="carrier_premium">
      <param name="proxy" value="172.28.0.1"/>
      <param name="port" value="5060"/>
      <param name="realm" value="172.28.0.1"/>
      <param name="register" value="false"/>
      <param name="caller-id-in-from" value="true"/>
      <param name="codec-prefs" value="PCMU,PCMA"/>
      <param name="enabled" value="true"/>
    </gateway>
    -->

    <!--
      Bandwidth Trunk Configuration 4 - GraniteTelecommunicationsLLC_O3
      Failover gateway for both trunks. Dallas proxy 67.231.2.12:5060
      Mapped to X-Carrier: backup
    -->
    <!-- DISABLED: Outbound calls now use sofia/external/dest@proxy with X-Carrier header
    <gateway name="carrier_backup">
      <param name="proxy" value="172.28.0.1"/>
      <param name="port" value="5060"/>
      <param name="realm" value="172.28.0.1"/>
      <param name="register" value="false"/>
      <param name="caller-id-in-from" value="true"/>
      <param name="codec-prefs" value="PCMU,PCMA"/>
      <param name="enabled" value="true"/>
    </gateway>
    -->

    <!--
      Test Gateway (Loopback for testing)
      Echoes audio back for testing without carrier
    -->
    <gateway name="test_echo">
      <param name="proxy" value="$${local_ip_v4}:5080"/>
      <param name="register" value="false"/>
      <param name="enabled" value="true"/>
    </gateway>
  </gateways>

  <!-- ============================================ -->
  <!-- DOMAIN HANDLING                             -->
  <!-- ============================================ -->
  <domains>
    <!-- Accept all domain requests (B2BUA mode) -->
    <domain name="all" alias="true" parse="true"/>
  </domains>
</profile>
