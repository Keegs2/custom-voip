<?xml version="1.0" encoding="utf-8"?>
<!--
  External SIP Profile - Carrier-Facing Outbound Calls
  This profile handles all outbound calls to carriers via Kamailio.

  Why a separate profile?
  The internal profile does NOT apply ext-sip-ip and ext-rtp-ip to
  outbound calls. Per FreeSWITCH design:
    - Internal profile: uses sip-ip (Docker 172.28.x.x) for Contact/Via on outbound
    - External profile: uses ext-sip-ip (public IP) for Contact/Via on outbound

  By bridging with sofia/external/dest@proxy instead of sofia/internal/dest@proxy,
  the outbound INVITE will have the public IP (34.74.71.32) in:
    - Contact header (ext-sip-ip)
    - Via header (ext-sip-ip)
    - SDP c=/m= lines (ext-rtp-ip)

  Architecture:
    Kamailio -> FreeSWITCH internal profile (:5080) - receives inbound calls
    FreeSWITCH external profile (:5090) -> Kamailio -> Bandwidth - sends outbound calls

  References:
    - https://developer.signalwire.com/freeswitch/FreeSWITCH-Explained/Configuration/Sofia-SIP-Stack/External-Profile_13173235/
    - https://developer.signalwire.com/freeswitch/FreeSWITCH-Explained/Configuration/Sofia-SIP-Stack/Outbound_profile_13174013/
-->
<profile name="external">
  <settings>
    <!-- ============================================ -->
    <!-- NETWORK CONFIGURATION                       -->
    <!-- ============================================ -->

    <!-- Listen on port 5090 for outbound calls -->
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="sip-port" value="5090"/>
    <param name="rtp-ip" value="$${local_ip_v4}"/>

    <!-- CRITICAL: External profile uses ext-sip-ip and ext-rtp-ip -->
    <!-- These control the IP in outbound Via, Contact, and SDP -->
    <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>
    <param name="ext-sip-ip" value="$${external_sip_ip}"/>

    <!-- ============================================ -->
    <!-- DIALPLAN CONFIGURATION                      -->
    <!-- ============================================ -->

    <!-- Context for any inbound on this profile (shouldn't happen) -->
    <param name="context" value="public"/>
    <param name="dialplan" value="XML"/>

    <!-- ============================================ -->
    <!-- CODEC CONFIGURATION                         -->
    <!-- ============================================ -->

    <param name="inbound-codec-prefs" value="PCMU,PCMA"/>
    <param name="outbound-codec-prefs" value="PCMU,PCMA"/>
    <param name="inbound-codec-negotiation" value="greedy"/>

    <!-- ============================================ -->
    <!-- AUTHENTICATION / SECURITY                   -->
    <!-- ============================================ -->

    <!-- No auth needed on external profile (carrier traffic) -->
    <param name="auth-calls" value="false"/>
    <param name="auth-all-packets" value="false"/>

    <!-- ============================================ -->
    <!-- NAT HANDLING / CONTACT IP SELECTION         -->
    <!-- ============================================ -->

    <!--
      CRITICAL: local-network-acl controls whether mod_sofia uses sip-ip
      or ext-sip-ip for the Contact header on outbound INVITEs.

      If the destination IP is in the local-network-acl, mod_sofia uses
      sip-ip (172.28.0.10 Docker IP) for Contact. If NOT in the ACL,
      it uses ext-sip-ip (public IP).

      Problem: The default local-network-acl includes RFC1918 ranges,
      so traffic to 172.28.0.1 (Kamailio Docker gateway) gets sip-ip
      in the Contact, producing "sip:mod_sofia@172.28.0.10:5090" which
      corrupts the outbound INVITE.

      Fix: Set to loopback.auto so only 127.0.0.0/8 is "local."
      All other destinations (including Docker 172.28.x.x) are treated
      as external, forcing ext-sip-ip into the Contact header.
    -->
    <param name="local-network-acl" value="loopback.auto"/>

    <!--
      Belt-and-suspenders: apply-nat-acl forces NAT handling (use of
      ext-sip-ip/ext-rtp-ip) for any destination matching RFC1918
      addresses. Since 172.28.0.1 is RFC1918, this ensures the public
      IP is used even if other ACL logic changes.
    -->
    <param name="apply-nat-acl" value="rfc1918.auto"/>

    <!-- NAT detection disabled — ext-sip-ip/ext-rtp-ip handle addressing -->
    <param name="aggressive-nat-detection" value="false"/>
    <param name="NDLB-force-rport" value="false"/>

    <!-- ============================================ -->
    <!-- SIP OPTIONS / FEATURES                      -->
    <!-- ============================================ -->

    <!-- Disable compact headers (Kamailio needs full-form) -->
    <param name="enable-compact-headers" value="false"/>

    <!-- No registration tracking needed -->
    <param name="manage-presence" value="false"/>
    <param name="track-calls" value="false"/>

    <!-- High volume settings -->
    <param name="max-proceeding" value="5000"/>
    <param name="reuse-connections" value="true"/>

    <!-- ============================================ -->
    <!-- SIP SESSION TIMERS (RFC 4028)               -->
    <!-- ============================================ -->
    <!--
      CRITICAL: Without session timer support on the carrier-facing profile,
      FreeSWITCH cannot negotiate or refresh sessions. If Bandwidth sends
      Session-Expires in the 200 OK and FreeSWITCH does not send a
      re-INVITE/UPDATE before it expires, the carrier tears down the call.

      enable-timer: Activates RFC 4028 session timer negotiation.
      sip-session-timeout: Our proposed session interval (30 min).
        The carrier may propose shorter; FS will negotiate per RFC 4028.
      minimum-session-expires: Floor for negotiation (see below).
    -->
    <param name="enable-timer" value="true"/>
    <param name="sip-session-timeout" value="1800"/>
    <param name="sip-min-session-expires" value="90"/>
    <!--
      minimum-session-expires: Floor for session timer negotiation.
      Set to 90s (matching internal profile) for carrier compatibility.
      Previously 120s, which could cause 422 rejection loops with carriers
      that propose intervals between 90-119s. 90s is the RFC 4028
      recommended minimum and balances refresh overhead vs. compatibility.
      Bandwidth typically proposes 30s; FS will send Min-SE:90 in the
      INVITE, and Bandwidth will negotiate up to at least 90s.
    -->
    <param name="minimum-session-expires" value="90"/>

    <!-- ============================================ -->
    <!-- DTMF CONFIGURATION                          -->
    <!-- ============================================ -->

    <param name="dtmf-type" value="rfc2833"/>

    <!-- ============================================ -->
    <!-- MEDIA HANDLING                              -->
    <!-- ============================================ -->

    <!-- User-Agent -->
    <param name="user-agent-string" value="VoicePlatform/1.0"/>

    <!-- RTP timeout -->
    <param name="rtp-timeout-sec" value="60"/>
    <param name="rtp-hold-timeout-sec" value="1800"/>

    <!-- ============================================ -->
    <!-- HOMER SIP CAPTURE (HEP)                     -->
    <!-- ============================================ -->
    <!--
      Send copies of all SIP messages to Homer via HEP protocol.
      capture-id 201 distinguishes this from the internal profile (200)
      and Kamailio (100) in Homer's SIP ladder diagrams.
    -->
    <param name="capture-server" value="udp:127.0.0.1:9060;hep=3;capture_id=201"/>
    <param name="sip-capture" value="yes"/>

  </settings>

  <gateways>
    <!-- No gateways needed — we bridge with sofia/external/dest@proxy -->
  </gateways>

  <domains>
    <domain name="all" alias="false" parse="false"/>
  </domains>
</profile>
