# Voice Platform Environment Configuration
# Copy this to .env and customize for your environment

# PostgreSQL
POSTGRES_DB=voip
POSTGRES_USER=voip
POSTGRES_PASSWORD=voip_secret

# Redis
REDIS_URL=redis://redis:6379

# FreeSWITCH
FREESWITCH_ESL_PASSWORD=ClueCon

# API
API_SECRET_KEY=your-secret-key-here
DEBUG=false

# Test Mode (disable carrier connections for testing)
TEST_MODE=true

# Carrier Settings (for production)
# CARRIER_PREMIUM_HOST=sip.carrier1.com
# CARRIER_PREMIUM_USER=username
# CARRIER_PREMIUM_PASS=password
# CARRIER_STANDARD_HOST=sip.carrier2.com
# CARRIER_STANDARD_USER=username
# CARRIER_STANDARD_PASS=password
